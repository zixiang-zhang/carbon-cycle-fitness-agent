# CarbonCycle-FitAgent 环境配置
# 复制此文件为 .env 并填写你的配置

# ========== 应用配置 ==========
APP_NAME=CarbonCycle-FitAgent
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ========== 数据库配置 ==========
DATABASE_URL=sqlite+aiosqlite:///./data/carboncycle.db

# ========== LLM 配置 ==========
# 支持多种 LLM 提供商，选择一种并配置：

# 选项1: 阿里云百炼 (Aliyun Bailian) - 推荐
LLM_PROVIDER=bailian
LLM_API_KEY=sk-your-bailian-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_BRAIN=qwen-max
LLM_MODEL_VISION=qwen-vl-max
LLM_MODEL_CHAT=qwen-plus

# 选项2: OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-openai-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_BRAIN=gpt-4
# LLM_MODEL_VISION=gpt-4-vision-preview
# LLM_MODEL_CHAT=gpt-4-turbo

# 选项3: Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-api03-your-anthropic-api-key
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL_BRAIN=claude-3-5-sonnet-20241022
# LLM_MODEL_CHAT=claude-3-haiku-20240307

# 选项4: 本地 Ollama
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL_BRAIN=llama3.1:70b
# LLM_MODEL_CHAT=qwen2.5:7b

# LLM 通用配置
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ========== Embedding 配置 ==========
# 选项1: Ollama + BGE-M3 (本地)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_DIMENSION=1024

# 选项2: OpenAI Embeddings
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# 选项3: HuggingFace
# EMBEDDING_PROVIDER=huggingface
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIMENSION=1024

# ========== 向量数据库 ==========
# ChromaDB (默认)
VECTOR_DB=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=carboncycle_knowledge

# Qdrant (替代方案)
# VECTOR_DB=qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION_NAME=carboncycle_knowledge

# ========== Agent 配置 ==========
AGENT_MAX_ITERATIONS=10
AGENT_REFLECTION_THRESHOLD=0.2
